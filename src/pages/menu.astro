---
import Layout from '../layouts/Layout.astro';
import { getMenuItems, getSiteSettings } from '../lib/content';

const [food, drinks, siteSettings] = await Promise.all([
  getMenuItems('food'),
  getMenuItems('drinks'),
  getSiteSettings()
]);
---

<Layout title={`Menu | ${siteSettings.businessName}`} description="Fresh-baked pretzels, pretzel dogs, and refreshing lemonade. Simple, delicious, made with love.">
  <!-- Hero -->
  <section class="bg-gradient-to-b from-salt-white to-warm-cream py-12">
    <div class="max-w-6xl mx-auto px-5 text-center">
      <h1 class="font-display text-4xl md:text-5xl font-bold text-deep-brown mb-4">
        Our Pretzel Menu
      </h1>
      <p class="text-lg text-sesame-brown max-w-2xl mx-auto">
        Fresh-baked pretzels and ice-cold lemonade. Made with love, simple ingredients, and old-fashioned techniques.
      </p>
    </div>
  </section>

  <!-- Food -->
  <section class="py-12 bg-salt-white">
    <div class="max-w-4xl mx-auto px-5">
      <h2 class="font-display text-3xl font-bold text-deep-brown mb-8 text-center">
        Food
      </h2>
      <div class="space-y-6">
        {food.map((item) => (
          <div class="bg-warm-cream rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow">
            <div class="flex flex-col md:flex-row">
              <div class="md:w-1/3 aspect-[4/3] md:aspect-square">
                {item.data.image ? (
                  <img
                    src={item.data.image}
                    alt={item.data.alt ?? item.data.name}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center bg-deep-brown text-warm-cream font-display text-2xl text-center p-6">
                    {item.data.name}
                  </div>
                )}
              </div>
              <div class="flex-1 p-6 flex flex-col justify-center">
                <div class="flex items-start justify-between gap-4 mb-2">
                  <h3 class="font-display text-xl font-semibold text-deep-brown">{item.data.name}</h3>
                  <span class="font-semibold text-caramel whitespace-nowrap">{item.data.price}</span>
                </div>
                <p class="text-sesame-brown text-sm">{item.data.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Drinks -->
  <section class="py-12 bg-warm-cream">
    <div class="max-w-4xl mx-auto px-5">
      <h2 class="font-display text-3xl font-bold text-deep-brown mb-8 text-center">
        Drinks
      </h2>
      <div class="space-y-6">
        {drinks.map((item) => (
          <div class="bg-salt-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow">
            <div class="flex flex-col md:flex-row">
              <div class="md:w-1/3 aspect-[4/3] md:aspect-square">
                {item.data.image ? (
                  <img
                    src={item.data.image}
                    alt={item.data.alt ?? item.data.name}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center bg-golden-crust text-salt-white font-display text-2xl text-center p-6">
                    {item.data.name}
                  </div>
                )}
              </div>
              <div class="flex-1 p-6 flex flex-col justify-center">
                <div class="flex items-start justify-between gap-4 mb-2">
                  <h3 class="font-display text-xl font-semibold text-deep-brown">{item.data.name}</h3>
                  <span class="font-semibold text-caramel whitespace-nowrap">{item.data.price}</span>
                </div>
                <p class="text-sesame-brown text-sm">{item.data.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Special Orders CTA -->
  <section class="py-12 bg-deep-brown text-warm-cream">
    <div class="max-w-3xl mx-auto px-5 text-center">
      <h2 class="font-display text-3xl font-bold text-salt-white mb-4">
        Need Something Special?
      </h2>
      <p class="text-lg mb-6">
        Planning an event or want a custom order? We'd love to help make your occasion extra special!
      </p>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 bg-golden-crust text-salt-white px-8 py-4 rounded-full font-semibold text-lg hover:bg-caramel transition-all"
      >
        Contact Us
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </section>
</Layout>
